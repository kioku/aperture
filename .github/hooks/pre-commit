#!/usr/bin/env bash

# Pre-commit hook for Aperture.
# Runs formatting (with auto-fix), linting, structural lint, and tests.

set -euo pipefail

# ── Self-update ───────────────────────────────────────────────────────────────
# Keep the installed hook in sync with the committed source automatically.
_HOOK_SOURCE="$(git rev-parse --show-toplevel 2>/dev/null)/.github/hooks/pre-commit"
if [ -f "$_HOOK_SOURCE" ] && ! diff -q "$_HOOK_SOURCE" "$0" > /dev/null 2>&1; then
    echo "Pre-commit hook updated — re-running with latest version."
    cp "$_HOOK_SOURCE" "$0"
    chmod +x "$0"
    exec "$0" "$@"
fi
unset _HOOK_SOURCE
# ─────────────────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

FAILED=0

run_step() {
    local label="$1"
    shift

    if "$@" > /dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} $label"
        return 0
    fi

    FAILED=1
    echo -e "  ${RED}✗${NC} $label"
    # Re-run without suppression so the developer sees the actual errors.
    echo ""
    "$@" 2>&1 || true
    echo ""
    return 1
}

is_rustfmt_diff_failure() {
    local output
    output="$("$@" 2>&1)" || true
    echo "$output" | grep -q '^Diff in '
}

echo -e "${GREEN}Running pre-commit checks...${NC}"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=d)"
if [ -z "$STAGED_FILES" ]; then
    echo -e "${YELLOW}No staged files found.${NC}"
    exit 0
fi

RUST_FILES="$(echo "$STAGED_FILES" | grep '\.rs$' || true)"

if [ -z "$RUST_FILES" ]; then
    echo -e "${YELLOW}No Rust files staged.${NC}"
    exit 0
fi

STAGED_COUNT="$(echo "$RUST_FILES" | wc -l | tr -d ' ')"
echo "Staged Rust files: $STAGED_COUNT"

# ── Format ────────────────────────────────────────────────────────────────────

if ! cargo fmt -- --check > /dev/null 2>&1; then
    if is_rustfmt_diff_failure cargo fmt -- --check; then
        echo -e "  ${YELLOW}↻${NC} cargo fmt (auto-fixing)"
        cargo fmt

        for file in $RUST_FILES; do
            [ -f "$file" ] && git add "$file"
        done
    else
        # Non-formatting failure (e.g. syntax error). Show it and bail.
        echo -e "  ${RED}✗${NC} cargo fmt"
        echo ""
        cargo fmt -- --check 2>&1 || true
        echo ""
        exit 1
    fi
else
    echo -e "  ${GREEN}✓${NC} cargo fmt"
fi

# ── Clippy ────────────────────────────────────────────────────────────────────

run_step "cargo clippy" \
    cargo clippy --all-targets --features integration --no-deps -- -D warnings

# ── ast-grep (staged files only) ─────────────────────────────────────────────

if command -v ast-grep &> /dev/null && [ -f "sgconfig.yml" ]; then
    # shellcheck disable=SC2086
    run_step "ast-grep scan" ast-grep scan $RUST_FILES
fi

# ── Tests ─────────────────────────────────────────────────────────────────────

run_step "cargo test" cargo test --features integration

# ── Result ────────────────────────────────────────────────────────────────────

echo ""
if [ "$FAILED" -ne 0 ]; then
    echo -e "${RED}Pre-commit checks failed.${NC}"
    exit 1
fi

echo -e "${GREEN}✅ All pre-commit checks passed.${NC}"
